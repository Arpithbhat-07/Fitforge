# Database Config
MONGO_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net
DB_NAME=fitforge

# Security
JWT_SECRET=super-secret-jwt-key-replace-in-production

# CORS (Supports multiple comma-separated URLs)
CORS_ORIGINS=https://fitforge.com,https://www.fitforge.com,https://fitforge.vercel.app

# Email Service (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=FitForge <noreply@yourdomain.com>
EMAIL_REPLY_TO=support@yourdomain.com

# Media Storage (Cloudinary - Required)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Default Admin Account Config
ADMIN_EMAIL=admin@fitforge.com
ADMIN_PASSWORD=FitForge@2026
